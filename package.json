{
  "name": "wshka",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "rm -rf .next/standalone/.next/static && mkdir -p .next/standalone/.next/static && cp -R .next/static/. .next/standalone/.next/static && cp -R public/. .next/standalone/public && node --env-file-if-exists=.env.local .next/standalone/server.js",
    "db:generate": "drizzle-kit generate --config config/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config config/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config config/drizzle.config.ts",
    "typecheck": "rm -rf .next && next typegen && tsc --noEmit",
    "test:unit": "vitest run tests/unit --config config/vitest.config.mts",
    "test:e2e": "playwright test --config config/playwright.config.ts"
  },
  "dependencies": {
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "drizzle-orm": "^0.45.2",
    "next": "^15.0.0",
    "pg": "^8.20.0",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "drizzle-kit": "^0.31.10",
    "vitest": "^4"
  }
}
